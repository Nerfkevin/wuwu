{
  "expo": {
    "name": "Wu-Wu",
    "slug": "wu-wu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wu-wu",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kevinngo03.wuwu",
      "infoPlist": {
        "SKIncludeConsumableInAppPurchaseHistory": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#111111"
      },
      "package": "com.nerfkevin.wuwu",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "posthog-react-native/expo",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#111111"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Wu-Wu to access your microphone to record your affirmations.",
          "recordAudioAndroid": true,
          "enableBackgroundPlayback": true
        }
      ],
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "Allow Wu-Wu to access your microphone to record your affirmations.",
          "iosBackgroundMode": true,
          "androidForegroundService": true
        }
      ],
      "expo-font",
      "expo-image",
      [
        "expo-secure-store",
        {
          "faceIDPermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "expo-web-browser",
      "expo-asset",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
